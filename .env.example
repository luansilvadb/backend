# Configurações do Backend Dashboard

# ID da planilha do Google Sheets para armazenar configurações
CONFIG_SPREADSHEET_ID=1uJiR89WOl6-JpVxNeirhopcPFoSN_KObWT-XSdOq0UI

# Chave secreta para geração de tokens JWT
JWT_SECRET=your-super-secret-key-change-in-production

# Tempo de expiração do token JWT
JWT_EXPIRES_IN=7d

# Porta do servidor
PORT=3000

# Ambiente (development, production)
NODE_ENV=development

# ===================================
# CONFIGURAÇÃO GOOGLE SHEETS
# ===================================
# Coloque o arquivo credentials.json da Service Account na raiz do projeto
# Para obter as credenciais:
# 1. Acesse https://console.cloud.google.com/
# 2. Crie um projeto ou use um existente
# 3. Ative a Google Sheets API
# 4. Crie uma Service Account
# 5. Baixe o arquivo JSON das credenciais
# 6. Renomeie para "credentials.json" e coloque na raiz

# ===================================
# INSTRUÇÕES DE SEGURANÇA
# ===================================
# - Nunca commite este arquivo com valores reais
# - Use variáveis de ambiente em produção
# - Mantenha JWT_SECRET complexo e único
# - Rotacione credenciais periodicamente
